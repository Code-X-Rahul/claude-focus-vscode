{
  "name": "claude-focus",
  "displayName": "Claude Focus",
  "description": "Automatically focuses VS Code window when Claude Code needs user action",
  "version": "1.0.0",
  "publisher": "evileye",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Code-X-Rahul/claude-focus-vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "focus",
    "window",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-focus.focusWindow",
        "title": "Claude Focus: Focus Window"
      },
      {
        "command": "claude-focus.setupHook",
        "title": "Claude Focus: Setup Claude Code Hook"
      },
      {
        "command": "claude-focus.removeHook",
        "title": "Claude Focus: Remove Claude Code Hook"
      }
    ],
    "configuration": {
      "title": "Claude Focus",
      "properties": {
        "claudeFocus.port": {
          "type": "number",
          "default": 19876,
          "description": "Port for the local HTTP server that listens for focus requests"
        },
        "claudeFocus.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable automatic window focusing"
        },
        "claudeFocus.showNotification": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when focusing the window"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "rm -f *.vsix && npx @vscode/vsce package",
    "install-ext": "npm run package && code --install-extension claude-focus-*.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
